        {
          "type": "frame",
          "id": "how148",
          "name": "How Timer Works Section",
          "fill": "#151922",
          "layout": "vertical",
          "gap": 6,
          "padding": 14,
          "cornerRadius": 8,
          "stroke": {
            "align": "inside",
            "fill": "#252B36",
            "thickness": 1
          },
          "children": [
            {
              "type": "text",
              "id": "t149",
              "name": "howTitle",
              "content": "How the Diablo 4 World Boss Timer Works",
              "fill": "#F8FAFC",
              "fontFamily": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
              "fontSize": 16,
              "fontWeight": "700",
              "width": "fill_container",
              "textGrowth": "fixed-width"
            },
            {
              "type": "text",
              "id": "t150",
              "name": "howSub1",
              "content": "How We Calculate the Next World Boss Spawn",
              "fill": "#A1A1AA",
              "fontFamily": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
              "fontSize": 13,
              "fontWeight": "600"
            },
            {
              "type": "text",
              "id": "t151",
              "name": "howBody1",
              "content": "The timer uses the known world boss rotation cycle (approximately every 3.5 hours) combined with community-verified spawn times to predict the next spawn. Confirmed times are manually reviewed or corrected by our team.",
              "fill": "#71717A",
              "fontFamily": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
              "fontSize": 12,
              "fontWeight": "400",
              "width": "fill_container",
              "textGrowth": "fixed-width",
              "lineHeight": 1.4
            },
            {
              "type": "text",
              "id": "t152",
              "name": "howSub2",
              "content": "Predicted vs Confirmed Spawn Times",
              "fill": "#A1A1AA",
              "fontFamily": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
              "fontSize": 13,
              "fontWeight": "600"
            },
            {
              "type": "text",
              "id": "t153",
              "name": "howBody2",
              "content": "Predicted times are generated from the rotation algorithm. Confirmed times have been manually verified. Needs verification means the anchor time requires community input.",
              "fill": "#71717A",
              "fontFamily": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
              "fontSize": 12,
              "fontWeight": "400",
              "width": "fill_container",
              "textGrowth": "fixed-width",
              "lineHeight": 1.4
            }
          ]
        },
        {
          "type": "frame",
          "id": "faq154",
          "name": "FAQ Section",
          "fill": "#151922",
          "layout": "vertical",
          "gap": 8,
          "padding": 14,
          "cornerRadius": 8,
          "stroke": {
            "align": "inside",
            "fill": "#252B36",
            "thickness": 1
          },
          "children": [
            {
              "type": "text",
              "id": "t155",
              "name": "faqTitle",
              "content": "Diablo 4 World Boss FAQ",
              "fill": "#F8FAFC",
              "fontFamily": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
              "fontSize": 16,
              "fontWeight": "700"
            },
            {
              "type": "frame",
              "id": "f158",
              "name": "faq item",
              "layout": "vertical",
              "gap": 3,
              "children": [
                {
                  "type": "text",
                  "id": "t156",
                  "name": "faqQuestion",
                  "content": "When is the next World Boss in Diablo 4?",
                  "fill": "#F8FAFC",
                  "fontFamily": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
                  "fontSize": 13,
                  "fontWeight": "700",
                  "width": "fill_container",
                  "textGrowth": "fixed-width"
                },
                {
                  "type": "text",
                  "id": "t157",
                  "name": "faqAnswer",
                  "content": "The next World Boss is shown in the timer card at the top of the page. It includes the boss name, live countdown, local spawn time, region, location, nearest waypoint, and confidence status.",
                  "fill": "#71717A",
                  "fontFamily": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
                  "fontSize": 12,
                  "fontWeight": "400",
                  "width": "fill_container",
                  "textGrowth": "fixed-width",
                  "lineHeight": 1.3
                }
              ]
            },
            {
              "type": "frame",
              "id": "f161",
              "name": "faq item",
              "layout": "vertical",
              "gap": 3,
              "children": [
                {
                  "type": "text",
                  "id": "t159",
                  "name": "faqQuestion",
                  "content": "How often do World Bosses spawn in Diablo 4?",
                  "fill": "#F8FAFC",
                  "fontFamily": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
                  "fontSize": 13,
                  "fontWeight": "700",
                  "width": "fill_container",
                  "textGrowth": "fixed-width"
                },
                {
                  "type": "text",
                  "id": "t160",
                  "name": "faqAnswer",
                  "content": "The timer uses a 210-minute, or 3.5-hour, interval as the default prediction rule. Future events are still labeled by confidence status because seasonal updates or special events may affect the schedule.",
                  "fill": "#71717A",
                  "fontFamily": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
                  "fontSize": 12,
                  "fontWeight": "400",
                  "width": "fill_container",
                  "textGrowth": "fixed-width",
                  "lineHeight": 1.3
                }
              ]
            },
            {
              "type": "frame",
              "id": "f164",
              "name": "faq item",
              "layout": "vertical",
              "gap": 3,
              "children": [
                {
                  "type": "text",
                  "id": "t162",
                  "name": "faqQuestion",
                  "content": "Where do World Bosses spawn in Diablo 4?",
                  "fill": "#F8FAFC",
                  "fontFamily": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
                  "fontSize": 13,
                  "fontWeight": "700",
                  "width": "fill_container",
                  "textGrowth": "fixed-width"
                },
                {
                  "type": "text",
                  "id": "t163",
                  "name": "faqAnswer",
                  "content": "World Bosses spawn in fixed arena locations across Sanctuary, including Fractured Peaks, Scosglen, Dry Steppes, Kehjistan, and Hawezar. The locations section shows the current spawn point, region, nearby waypoint, and map option.",
                  "fill": "#71717A",
                  "fontFamily": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
                  "fontSize": 12,
                  "fontWeight": "400",
                  "width": "fill_container",
                  "textGrowth": "fixed-width",
                  "lineHeight": 1.3
                }
              ]
            },
            {
              "type": "frame",
              "id": "f167",
              "name": "faq item",
              "layout": "vertical",
              "gap": 3,
              "children": [
                {
                  "type": "text",
                  "id": "t165",
                  "name": "faqQuestion",
                  "content": "Is this Diablo 4 World Boss Timer accurate?",
                  "fill": "#F8FAFC",
                  "fontFamily": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
                  "fontSize": 13,
                  "fontWeight": "700",
                  "width": "fill_container",
                  "textGrowth": "fixed-width"
                },
                {
                  "type": "text",
                  "id": "t166",
                  "name": "faqAnswer",
                  "content": "This Diablo 4 World Boss Timer is designed to be transparent rather than overpromise. Confirmed events have been reviewed, Predicted events are generated from the current rotation logic, and Needs verification events should be checked before you rely on them.",
                  "fill": "#71717A",
                  "fontFamily": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
                  "fontSize": 12,
                  "fontWeight": "400",
                  "width": "fill_container",
                  "textGrowth": "fixed-width",
                  "lineHeight": 1.3
                }
              ]
            },
            {
              "type": "frame",
              "id": "f170",
              "name": "faq item",
              "layout": "vertical",
              "gap": 3,
              "children": [
                {
                  "type": "text",
                  "id": "t168",
                  "name": "faqQuestion",
                  "content": "Can I get a reminder before a World Boss spawns?",
                  "fill": "#F8FAFC",
                  "fontFamily": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
                  "fontSize": 13,
                  "fontWeight": "700",
                  "width": "fill_container",
                  "textGrowth": "fixed-width"
                },
                {
                  "type": "text",
                  "id": "t169",
                  "name": "faqAnswer",
                  "content": "Yes. The reminder panel can support warning times such as 5, 15, 30, or 60 minutes before the event. Browser notification permission should only be requested after you choose a reminder.",
                  "fill": "#71717A",
                  "fontFamily": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
                  "fontSize": 12,
                  "fontWeight": "400",
                  "width": "fill_container",
                  "textGrowth": "fixed-width",
                  "lineHeight": 1.3
                }
              ]
            },
            {
              "type": "frame",
              "id": "f173",
              "name": "faq item",
              "layout": "vertical",
              "gap": 3,
              "children": [
                {
                  "type": "text",
                  "id": "t171",
                  "name": "faqQuestion",
                  "content": "Does the timer show my local time?",
                  "fill": "#F8FAFC",
                  "fontFamily": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
                  "fontSize": 13,
                  "fontWeight": "700",
                  "width": "fill_container",
                  "textGrowth": "fixed-width"
                },
                {
                  "type": "text",
                  "id": "t172",
                  "name": "faqAnswer",
                  "content": "Yes. Event times are stored in UTC and converted in your browser so the timer can show the next spawn in your local timezone.",
                  "fill": "#71717A",
                  "fontFamily": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
                  "fontSize": 12,
                  "fontWeight": "400",
                  "width": "fill_container",
                  "textGrowth": "fixed-width",
                  "lineHeight": 1.3
                }
              ]
            },
            {
              "type": "frame",
              "id": "f176",
              "name": "faq item",
              "layout": "vertical",
              "gap": 3,
              "children": [
                {
                  "type": "text",
                  "id": "t174",
                  "name": "faqQuestion",
                  "content": "What do World Bosses drop in Diablo 4?",
                  "fill": "#F8FAFC",
                  "fontFamily": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
                  "fontSize": 13,
                  "fontWeight": "700",
                  "width": "fill_container",
                  "textGrowth": "fixed-width"
                },
                {
                  "type": "text",
                  "id": "t175",
                  "name": "faqAnswer",
                  "content": "World Bosses may drop Grand Caches, legendary gear, cosmetics, mount armor, trophies, and seasonal rewards. The rewards section gives a quick overview so you can decide whether the next event is worth joining.",
                  "fill": "#71717A",
                  "fontFamily": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
                  "fontSize": 12,
                  "fontWeight": "400",
                  "width": "fill_container",
                  "textGrowth": "fixed-width",
                  "lineHeight": 1.3
                }
              ]
            }
          ]
        },
        {
