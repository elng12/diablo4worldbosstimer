# Required: Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:pass@host/database?sslmode=require

# Required: Admin API token for /api/admin/* endpoints (use a strong random string in production)
ADMIN_API_TOKEN=

# Required: Cron secret for /api/cron/* endpoints (use a strong random string in production)
CRON_SECRET=

# Optional: Public site URL used for canonical URLs and JSON-LD (defaults to https://example.com)
NEXT_PUBLIC_SITE_URL=https://example.com
